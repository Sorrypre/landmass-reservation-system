					<div class="space"></div>
					<div class="seat disabled" data-pc="10"></div>
					<div class="seat disabled" data-pc="11"></div>
					<div class="seat disabled" data-pc="12"></div>
				</div>

				<div class="row" id="row-3">
					<div class="seat disabled" data-pc="13"></div>
					<div class="seat disabled" data-pc="14"></div>
					<div class="seat disabled" data-pc="15"></div>
					<div class="space"></div>
					<div class="seat disabled" data-pc="16"></div>
					<div class="seat disabled" data-pc="17"></div>
					<div class="seat disabled" data-pc="18"></div>
				</div>

				<div class="row" id="row-4">
