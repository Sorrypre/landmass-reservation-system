		<div id="seat-selection">
			<div class="seat-legend">
				<div class="seat"></div>
				<span>Available</span>
				<div class="seat taken"></div>
				<span>Taken</span>
				<div class="seat selected"></div>
				<span>Selected</span>
			</div>
			<div id="slots-container">
				<div class="whiteboard">Whiteboard</div>
				<div class="row" id="row-1">
					<div class="seat disabled" data-pc="1"></div>
					<div class="seat disabled" data-pc="2"></div>
					<div class="seat disabled" data-pc="3"></div>
					<div class="space"></div>
					<div class="seat disabled" data-pc="4"></div>
					<div class="seat disabled" data-pc="5"></div>
					<div class="seat disabled" data-pc="6"></div>
				</div>

				<div class="row" id="row-2">
